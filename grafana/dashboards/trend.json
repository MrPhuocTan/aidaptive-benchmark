{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "title": "GPU Utilization - Realtime",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "aidaptive-influxdb" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "opacity"
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "server1" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#6b7280", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": "server2" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#a855f7", "mode": "fixed" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "query": "from(bucket: \"benchmarks\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"hardware_metrics\")\n  |> filter(fn: (r) => r._field == \"gpu_util_pct\")\n  |> group(columns: [\"server\"])\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)",
          "refId": "A"
        }
      ]
    },
